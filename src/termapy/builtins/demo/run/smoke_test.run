# Smoke test for demo device
# Exercises all ASCII commands with screenshots
/ss.dir demo_smoke_{starttime}
/print === Demo smoke test started {starttime} ===

# Section 1: basic commands
/cls
help
/delay 500ms
/ss.svg s{seq2+}_{seq1+}_help
/ss.txt s{seq2}_{seq1}_help

/cls
AT
/delay 200ms
AT+INFO
/delay 500ms
/ss.svg s{seq2}_{seq1+}_info
/ss.txt s{seq2}_{seq1}_info

# Section 2: sensors and LED
/cls
AT+TEMP
/delay 200ms
AT+TEMP
/delay 200ms
AT+TEMP
/delay 500ms
/ss.svg s{seq2+}_{seq1+}_temp
/ss.txt s{seq2}_{seq1}_temp

/cls
AT+LED on
/delay 200ms
AT+STATUS
/delay 500ms
/ss.svg s{seq2}_{seq1+}_led_on
/ss.txt s{seq2}_{seq1}_led_on

AT+LED off
/delay 200ms
AT+STATUS
/delay 500ms
/ss.svg s{seq2}_{seq1+}_led_off
/ss.txt s{seq2}_{seq1}_led_off

# Section 3: memory dump
/cls
mem 0x1000 64
/delay 500ms
/ss.svg s{seq2+}_{seq1+}_mem64
/ss.txt s{seq2}_{seq1}_mem64

# Section 4: reset
/cls
AT+RESET
/delay 1s
/ss.svg s{seq2+}_{seq1+}_reset
/ss.txt s{seq2}_{seq1}_reset

/print === Demo smoke test done ===
/seq
