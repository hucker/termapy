{
    "config_version": 3,
    "title": "Demo Device",
    "app_border_color": "",
    "max_lines": 10000,
    "repl_prefix": "!",
    "os_cmd_enabled": false,
    "port": "DEMO",
    "baudrate": 115200,
    "bytesize": 8,
    "parity": "N",
    "stopbits": 1,
    "flow_control": "none",
    "encoding": "utf-8",
    "inter_cmd_delay_ms": 0,
    "autoconnect": true,
    "autoreconnect": true,
    "autoconnect_cmd": "",
    "line_ending": "\r",
    "echo_cmd": true,
    "echo_cmd_fmt": "[purple]> {cmd}[/]",
    "log_file": "",
    "show_timestamps": false,
    "show_eol": false,
    "exception_traceback": true,
    "max_grep_lines": 100,
    "command_history_items": 30,
    "custom_buttons": [
        {"enabled": true, "name": "Demo Help", "command": "!clr\\nHELP", "tooltip": "Clear screen and show device commands"},
        {"enabled": true, "name": "AT Demo", "command": "!clr\\n!run at_demo.run", "tooltip": "Run all AT commands with delays"},
        {"enabled": false, "name": "Btn3", "command": "", "tooltip": "Custom button 3"},
        {"enabled": false, "name": "Btn4", "command": "", "tooltip": "Custom button 4"}
    ]
}
