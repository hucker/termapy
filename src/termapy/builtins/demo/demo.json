{
    "config_version": 4,
    "title": "Demo Device",
    "app_border_color": "",
    "max_lines": 10000,
    "repl_prefix": "/",
    "read_only": false,
    "os_cmd_enabled": false,
    "port": "DEMO",
    "baud_rate": 115200,
    "byte_size": 8,
    "parity": "N",
    "stop_bits": 1,
    "flow_control": "none",
    "encoding": "utf-8",
    "inter_cmd_delay_ms": 0,
    "auto_connect": true,
    "auto_reconnect": true,
    "auto_connect_cmd": "",
    "line_ending": "\r",
    "echo_cmd": true,
    "echo_cmd_fmt": "[purple]> {cmd}[/]",
    "log_file": "",
    "show_timestamps": false,
    "show_eol": false,
    "exception_traceback": true,
    "max_grep_lines": 100,
    "custom_buttons": [
        {"enabled": true, "name": "Demo Help", "command": "/cls\\nHELP", "tooltip": "Clear screen and show device commands"},
        {"enabled": true, "name": "AT Demo", "command": "/cls\\n/run at_demo.run", "tooltip": "Run all AT commands with delays"},
        {"enabled": true, "name": "Info", "command": "/info", "tooltip": "Project info"},
        {"enabled": true, "name": "Probe", "command": "/probe", "tooltip": "Demo plugin: query the device"}
    ]
}
