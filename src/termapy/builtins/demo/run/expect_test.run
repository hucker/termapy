# Expect command test
# Test 1: AT returns OK -- should match
AT
/expect match=OK

# Test 2: AT+INFO returns Bassomatic -- should match
AT+INFO
/expect timeout=2s match=Bassomatic

# Test 3: regex match on temperature
AT+TEMP
/expect.regex timeout=2s match=\d+\.\d+C

# Test 4: should timeout and abort
AT
/expect timeout=2s match=NOPE
